# ============================================================
#  Paradise Resort — Email Configuration
#  
#  INSTRUCTIONS:
#  1. Copy this file and rename it to exactly:  .env
#  2. Fill in your Gmail details below
#  3. Save the file then restart: python run.py
# ============================================================

# Your Gmail address
SMTP_USER=yourgmail@gmail.com

# Gmail App Password (16 characters, spaces are OK to include)
# Get it at: https://myaccount.google.com/apppasswords
# Make sure 2-Step Verification is ON first
SMTP_PASS=xxxx xxxx xxxx xxxx

# Leave these as-is for Gmail
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=Paradise Resort
